{
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(.venv/bin/pytest *)",
      "Bash(.venv/bin/python *)",
      "Bash(.venv/bin/pip install *)",
      "Bash(.venv/bin/ruff *)",
      "Bash(.venv/bin/lint-imports *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status*)",
      "Bash(git show *)",
      "Bash(git stash*)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git push --force*)",
      "Bash(rm -rf *)",
      "Bash(curl * | bash*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/validate_architecture.py"
          }
        ]
      }
    ]
  }
}
