<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to {{app_name}}</title>
</head>
<body style="margin:0;font-family:arial">
    <table style="border:0;width:100%">
        <tr style="background:#eeeeee">
            <td style="padding:20px;color:#808080;text-align:center;font-size:40px;font-weight:600">
                {{app_name}}
            </td>
        </tr>
        <tr>
            <td style="padding:20px;color:#808080;font-size:16px;font-weight:100">
                Hi {{name}},<br><br>
                Your business owner account for <strong>{{businessName}}</strong> has been created.<br><br>
                You can log in to manage your loyalty program using the credentials below:
            </td>
        </tr>
        <tr>
            <td style="padding:0 20px 20px">
                <table style="background:#f5f5f5;border-radius:8px;padding:16px;width:100%">
                    <tr>
                        <td style="color:#808080;font-size:14px;padding:4px 0">
                            <strong>Login URL:</strong> {{loginUrl}}
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#808080;font-size:14px;padding:4px 0">
                            <strong>Temporary Password:</strong> {{tempPassword}}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <tr>
            <td style="text-align:center;padding-bottom:20px">
                <a href="{{loginUrl}}"
                    style="display:inline-block;padding:20px;background:#00838f;text-decoration:none;color:#ffffff">
                    Go to Admin Panel
                </a>
            </td>
        </tr>
        <tr>
            <td style="padding:0 20px 20px;color:#aaaaaa;font-size:12px">
                Please change your password after first login. If you did not expect this email, please ignore it.
            </td>
        </tr>
    </table>
</body>
</html>
